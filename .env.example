# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your real keys or location.

# ── API Keys ──────────────────────────────────────────────────────────────
# Required: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required: https://api.congress.gov/sign-up/
CONGRESS_API_KEY=your_congress_api_key_here

# Optional: https://openstates.org/accounts/signup/
# Without this, state bills won't be fetched.
OPENSTATES_API_KEY=your_openstates_api_key_here

# Required for podcast generation (TTS). Pay-as-you-go.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── User Location ─────────────────────────────────────────────────────────
# The scanner uses these to prioritize items that affect you. All optional —
# leave blank to skip. Defaults assume Maryland / Montgomery County.
USER_STATE=Maryland
USER_STATE_CODE=md
USER_COUNTY=Montgomery County
USER_CITY=
USER_ZIP_CODE=

# Electoral districts (leave blank if unknown)
US_HOUSE_DISTRICT=
STATE_SENATE_DISTRICT=
STATE_HOUSE_DISTRICT=
COUNTY_COUNCIL_DISTRICT=

# ── Federal topic filter ──────────────────────────────────────────────────
# Comma-separated list of keywords. Federal items must match at least one to
# be AI-summarized (federal news is massive; this keeps costs and noise down).
# Leave unset to use the neutral default list in config.py.
# FEDERAL_KEYWORDS=budget, appropriations, healthcare, education, housing
